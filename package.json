{
  "name": "roblox-mcp-pro",
  "version": "0.1.0",
  "description": "Open MCP server that lets AI agents control Roblox Studio: live execution, instance query/mutate, and bidirectional Studio<->local sync.",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "roblox-mcp-pro": "dist/index.js"
  },
  "files": [
    "dist",
    "plugin",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "inspector": "npx @modelcontextprotocol/inspector node dist/index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "chokidar": "^4.0.3",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
