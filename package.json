{
  "name": "roblox-mcp-pro",
  "version": "1.0.49",
  "description": "Free, open-source MCP server that lets AI agents control Roblox Studio: live Luau execution, instance query/mutate, UI/terrain/lighting, and bidirectional Studio<->local sync.",
  "license": "MIT",
  "author": "Peerapol",
  "homepage": "https://peerapolselanon.github.io/roblox-mcp-pro/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PeerapolSelanon/roblox-mcp-pro.git"
  },
  "bugs": {
    "url": "https://github.com/PeerapolSelanon/roblox-mcp-pro/issues"
  },
  "keywords": [
    "roblox",
    "roblox-studio",
    "mcp",
    "model-context-protocol",
    "claude",
    "luau",
    "ai",
    "studio-plugin"
  ],
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "roblox-mcp-pro": "dist/index.js"
  },
  "files": [
    "dist",
    "plugin/src",
    "plugin/default.project.json",
    "plugin/RobloxMcpPro.rbxmx",
    ".agents/skills/roblox-mcp-pro",
    ".agents/skills/roblox-mcp-multi-agent",
    ".agents/skills/roblox-studio-plugin",
    ".agents/skills/roblox-ui-animation",
    ".agents/skills/roblox-ui-from-image",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "inspector": "npx @modelcontextprotocol/inspector node dist/index.js",
    "docs": "node scripts/gen-docs.mjs",
    "version": "npm run docs && git add .agents/skills/roblox-mcp-pro/references/tools.md",
    "lint": "biome lint",
    "test": "npm run build && node scripts/smoke.mjs && node scripts/routing-smoke.mjs && node scripts/sync-smoke.mjs && node scripts/analyze-smoke.mjs && node scripts/png-smoke.mjs && npx tsx --test test/*.test.ts",
    "prepublishOnly": "npm run clean && npm run build && npm run docs"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "chokidar": "^4.0.3",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
