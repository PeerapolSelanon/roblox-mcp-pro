{
  "name": "roblox-mcp-pro",
  "version": "0.2.3",
  "description": "MCP server that lets AI agents control Roblox Studio: live Luau execution, instance query/mutate, UI/terrain/lighting, and bidirectional Studio<->local sync. Paid subscription with a free trial.",
  "license": "SEE LICENSE IN LICENSE",
  "author": "Peerapol",
  "homepage": "https://github.com/PeerapolSelanon/roblox-mcp-pro#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PeerapolSelanon/roblox-mcp-pro.git"
  },
  "bugs": {
    "url": "https://github.com/PeerapolSelanon/roblox-mcp-pro/issues"
  },
  "keywords": [
    "roblox",
    "roblox-studio",
    "mcp",
    "model-context-protocol",
    "claude",
    "luau",
    "ai",
    "studio-plugin"
  ],
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "roblox-mcp-pro": "dist/index.js"
  },
  "files": [
    "dist",
    "plugin/src",
    "plugin/default.project.json",
    "plugin/RobloxMcpPro.rbxmx",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "inspector": "npx @modelcontextprotocol/inspector node dist/index.js",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "chokidar": "^4.0.3",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
